# 美搭 · 环境变量清单
# 本地：复制本文件为 server/.env 填真实值（.env 不进 git，密钥找项目负责人要）
# 线上（Vercel）：在 项目 Settings → Environment Variables 逐条配置，改后需 Redeploy
# 留空的项会走降级：AI→本地模拟、Supabase→只用本机、DirectMail→验证码页面直发(devCode)

# ── 鉴权（线上必填）────────────────────────────────
# 一串随机长字符串，签名验证码与登录 token。线上漏配会直接拒绝启动，绝不能用默认值。
# 生成：openssl rand -hex 32
AUTH_SECRET=

# ── AI 模型（做真实 AI 能力时填；留空则本地模拟/叠图，零成本）──
# 识别打标签 / 虚拟试穿，走 OpenRouter   https://openrouter.ai/keys
OPENROUTER_API_KEY=
# 拆图白底平铺图，走阿里云百炼 qwen-image-edit   https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=
# 【业务空间密钥(sk-ws-开头)必填】其专属调用域名；公共域名会报 InvalidApiKey。
# 普通主账号密钥(sk-开头)可留空，走默认公共域名。
DASHSCOPE_API_BASE=https://ws-v5gwko8ozm2t8ets.cn-beijing.maas.aliyuncs.com

# ── 用户轻量资料云端持久化（Supabase；留空只用本机 localStorage，换设备不同步）──
# Supabase 项目 Settings → Data API 的 Project URL（到 .supabase.co 为止，不带 /rest/v1）
SUPABASE_URL=https://xxxxxxxx.supabase.co
# Settings → API Keys 的 service_role(secret) 密钥（不是 anon/public）
SUPABASE_SERVICE_KEY=

# ── 邮箱验证码发信（阿里云邮件推送 DirectMail；留空验证码走页面 devCode 直发）──
# RAM 子用户的 AccessKey（权限 AliyunDirectMailFullAccess）
DM_ACCESS_KEY_ID=
DM_ACCESS_KEY_SECRET=
# 发信地址（DirectMail 里建的，默认已对上，可不改）
DM_ACCOUNT=noreply@mail.meidaai.com
# DM_FROM_ALIAS=美搭
# DM_ENDPOINT=https://dm.aliyuncs.com/

# ── 每日配额（可选；留空走默认 拆图5次/试穿20次，设 0=不限）──
# QUOTA_SPLIT_PER_DAY=5
# QUOTA_TRYON_PER_DAY=20
